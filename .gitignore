# Data are not tracked
data/
*.parquet
*.csv
*.tsv
data/**/*.txt

# Generated outputs are not tracked
result/
results/
models/
figures/
*.pkl
*.joblib

# Python cache
__pycache__/
*.pyc
.ipynb_checkpoints/

# Editor and OS files
.DS_Store
Thumbs.db
.vscode/
.idea/

# LaTeX artifacts, if copied locally
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.xdv
*.synctex.gz
